{
  "manifest_version": 3,
  "name": "ChatGPT Assistant",
  "version": "1.0.0",
  "description": "Tự động mở ChatGPT và xử lý prompt từ cấu hình",
  "oauth2": {
    "client_id": "1061609434838-glhk7tcpa604kbvl28e7qsqt3tg1ge86.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/drive.file"]
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "sidePanel",
    "identity",
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://iboard-query.ssi.com.vn/*",
    "https://iboard.ssi.com.vn/*"
  ],
  "action": {
    "default_title": "ChatGPT Assistant"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "images/icon-16.svg",
    "48": "images/icon-48.svg",
    "128": "images/icon-128.svg"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["prompts/*.md"],
      "matches": ["<all_urls>"]
    }
  ]
}
