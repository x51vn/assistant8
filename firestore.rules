rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for security
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    function isValidBackup(data) {
      // Allow any backup structure with basic fields
      return data.size() > 0 
        && (data.keys().hasAny(['version', 'exportDate', 'data', 'syncedAt']));
    }
    
    function isValidConfig(data) {
      // Config can have any of these fields
      return data.size() > 0;
    }
    
    // Require authentication
    match /users/{uid} {
      // Users can only access their own data
      allow read: if isOwner(uid);
      allow write: if false; // Prevent direct user doc writes
      
      // Backups subcollection
      match /backups/{backupId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidBackup(request.resource.data);
        allow update: if false; // Backups are immutable once created
        allow delete: if isOwner(uid);
      }
      
      // Config subcollection  
      match /config/{configId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidConfig(request.resource.data);
        allow update: if isOwner(uid) && isValidConfig(request.resource.data);
        allow delete: if isOwner(uid);
      }
      
      // Data subcollection (chatHistory, errorList, runs, etc.)
      match /data/{dataType} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
