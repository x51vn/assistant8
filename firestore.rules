rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ========== HELPER FUNCTIONS ==========
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    // X51LABS-72: Size limit validation (1MB = 1,048,576 bytes)
    function isWithinSizeLimit(data) {
      // Firestore enforces 1MB per document, we enforce 800KB to be safe
      return request.resource.size < 819200; // 800KB
    }
    
    // X51LABS-72: Validate backup data structure
    function isValidBackup() {
      let data = request.resource.data;
      return data.keys().hasAll(['backupId', 'version', 'data']) &&
             data.backupId is string &&
             data.version is string &&
             data.data is map;
    }
    
    // X51LABS-72: Rate limiting - max 1 backup per minute
    function isRateLimitOk(uid) {
      // Check if there's a recent backup (within last 60 seconds)
      // This is a simplified check; for production, use server-side logic
      return true; // TODO: Implement server-side rate limiting
    }
    
    // X51LABS-72: Validate config data
    function isValidConfig() {
      let data = request.resource.data;
      // Config docs must have either 'backupId' (latestBackup) or valid config fields
      return (data.keys().hasAll(['backupId']) && data.backupId is string) ||
             (data.keys().hasAny(['settings', 'preferences']));
    }
    
    // ===== PRODUCTION RULES - SECURE & VALIDATED =====
    match /users/{uid} {
      // Users can read their own user doc
      allow read: if isOwner(uid);
      allow write: if false;
      
      // X51LABS-72: Backups subcollection - TIGHTENED
      match /backups/{backupId} {
        // READ: Owner can read their backups
        allow read: if isOwner(uid);
        
        // CREATE: Owner can create if valid structure + within size limit
        allow create: if isOwner(uid) && 
                        isValidBackup() && 
                        isWithinSizeLimit(request.resource.data);
        
        // UPDATE: Not allowed (backups are immutable)
        allow update: if false;
        
        // DELETE: Owner can delete old backups
        allow delete: if isOwner(uid);
      }
      
      // X51LABS-72: Config subcollection - VALIDATED
      match /config/{configId} {
        allow read: if isOwner(uid);
        
        // CREATE/UPDATE: Must have valid structure
        allow create, update: if isOwner(uid) && 
                                 isValidConfig() &&
                                 isWithinSizeLimit(request.resource.data);
        
        allow delete: if isOwner(uid);
      }
      
      // X51LABS-72: Data subcollection - SIZE LIMITED
      match /data/{dataType} {
        allow read: if isOwner(uid);
        
        // CREATE/UPDATE: Enforce size limits
        allow create, update: if isOwner(uid) && 
                                 isWithinSizeLimit(request.resource.data);
        
        allow delete: if isOwner(uid);
      }
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
