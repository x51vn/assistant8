rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    
    // ===== PRODUCTION RULES - MINIMAL & PERMISSIVE =====
    match /users/{uid} {
      // Users can read their own user doc
      allow read: if isOwner(uid);
      allow write: if false;
      
      // Backups subcollection - allow owner to create/read/delete
      match /backups/{backupId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }
      
      // Config subcollection - allow owner to do anything
      match /config/{configId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }
      
      // Data subcollection - allow owner to do anything
      match /data/{dataType} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
