{
  "manifest_version": 3,
  "name": "ChatGPT Assistant",
  "version": "1.0.0",
  "description": "Tự động mở ChatGPT và xử lý prompt từ cấu hình",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "sidePanel",
    "contextMenus",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://www.google.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://iboard-query.ssi.com.vn/*",
    "https://iboard.ssi.com.vn/*",
    "https://bgapidatafeed.vps.com.vn/*",
    "https://*.supabase.co/*",
    "https://btmc.vn/*",
    "https://www.btmc.vn/*",
    "https://giavang.doji.vn/*",
    "https://sjc.com.vn/*",
    "https://api.coingecko.com/*",
    "https://api.binance.com/*",
    "https://*.atlassian.net/*",
    "https://api.x51.vn/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "ChatGPT Assistant"
  },

  "side_panel": {
    "default_path": "sidepanel-preact.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "images/icon-16.svg",
    "48": "images/icon-48.svg",
    "128": "images/icon-128.svg"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "all_frames": false,
      "type": "module"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content-gemini.js"],
      "all_frames": false,
      "type": "module"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content-claude.js"],
      "all_frames": false,
      "type": "module"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["prompts/*.md"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["privacy-policy.html", "terms-of-service.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
