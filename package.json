{
  "name": "chatgpt-extension",
  "version": "1.0.0",
  "description": "trợ lý cá nhân",
  "author": "vudu",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "test:unit": "vitest",
    "test:unit:run": "vitest --run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/extension-load.spec.js",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "check:repo-hygiene": "node scripts/check-repo-hygiene.mjs",
    "check:openspec": "openspec validate --all",
    "smoke:extension": "npm run build && node scripts/check-extension-smoke.mjs"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.3.1",
    "@playwright/test": "^1.48.0",
    "@preact/preset-vite": "^2.10.3",
    "@testing-library/preact": "^2.0.1",
    "@testing-library/preact-hooks": "^1.1.0",
    "happy-dom": "^20.4.0",
    "jsdom": "^27.0.1",
    "playwright": "^1.57.0",
    "supabase": "^2.76.12",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@preact/signals": "^1.3.3",
    "@supabase/supabase-js": "^2.91.0",
    "jsonrepair": "^3.13.2",
    "p-queue": "^9.1.0",
    "preact": "^10.28.2"
  }
}
