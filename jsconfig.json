{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "strict": false,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["chrome"],
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noEmit": true,
    "allowArbitraryExtensions": true
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
