{
  "name": "ChatGPT Assistant Extension Config",
  "version": "1.0",
  "description": "Configuration template for ChatGPT Assistant Extension",
  "author": "GitHub Copilot",
  "created": "2026-01-05",
  "settings": {
    "prompt": {
      "type": "string",
      "default": "",
      "description": "The prompt to send to ChatGPT",
      "maxLength": 5000,
      "required": true
    },
    "autoRun": {
      "type": "boolean",
      "default": false,
      "description": "Whether to automatically run the prompt",
      "required": false
    },
    "interval": {
      "type": "number",
      "default": 5,
      "description": "Interval in minutes between auto runs",
      "min": 1,
      "max": 1440,
      "required": false
    },
    "chatgptUrl": {
      "type": "string",
      "default": "https://chatgpt.com",
      "description": "ChatGPT base URL",
      "readOnly": true
    },
    "resultUpdateTime": {
      "type": "number",
      "description": "Timestamp of last result update",
      "readOnly": true
    },
    "lastPromptSent": {
      "type": "string",
      "description": "The last prompt that was sent",
      "readOnly": true
    }
  },
  "presets": {
    "learning": {
      "prompt": "Giải thích {topic} một cách dễ hiểu với ví dụ cụ thể",
      "autoRun": false,
      "interval": 5,
      "description": "Template for learning new concepts"
    },
    "coding": {
      "prompt": "Viết code {language} để {task}",
      "autoRun": false,
      "interval": 5,
      "description": "Template for generating code"
    },
    "news": {
      "prompt": "Tóm tắt 3 tin tức mới nhất về {topic}",
      "autoRun": true,
      "interval": 30,
      "description": "Template for news summarization"
    },
    "brainstorm": {
      "prompt": "Đưa ra 5 ý tưởng sáng tạo về {topic}",
      "autoRun": false,
      "interval": 10,
      "description": "Template for brainstorming"
    },
    "writing": {
      "prompt": "Viết một bài {type} về {topic}",
      "autoRun": false,
      "interval": 10,
      "description": "Template for content writing"
    }
  },
  "examples": {
    "example1": {
      "name": "AI Explanation",
      "prompt": "Hãy giải thích Machine Learning là gì?",
      "autoRun": false,
      "interval": 5
    },
    "example2": {
      "name": "Code Generation",
      "prompt": "Viết một function Python để tính Fibonacci",
      "autoRun": false,
      "interval": 5
    },
    "example3": {
      "name": "News Summary",
      "prompt": "Tóm tắt 3 tin tức công nghệ hôm nay",
      "autoRun": true,
      "interval": 60
    },
    "example4": {
      "name": "Creative Ideas",
      "prompt": "Đưa ra 3 ý tưởng sáng tạo cho startup",
      "autoRun": false,
      "interval": 5
    }
  },
  "validationRules": {
    "prompt": {
      "notEmpty": true,
      "maxLength": 5000,
      "pattern": ".*\\S.*"
    },
    "interval": {
      "min": 1,
      "max": 1440
    }
  },
  "storageLimits": {
    "maxPromptLength": 5000,
    "maxSettingsSize": "10 MB",
    "maxHistoryItems": 100
  },
  "defaults": {
    "chatgptUrl": "https://chatgpt.com",
    "fallbackUrl": "https://chat.openai.com",
    "timeout": 30000,
    "retryAttempts": 3,
    "debounceDelay": 500
  },
  "timingConfig": {
    "inputDelay": 500,
    "clickDelay": 500,
    "resultFetchDelay": 3000,
    "messageChechInterval": 1000
  }
}
